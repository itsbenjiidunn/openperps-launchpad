# Optional. A Solana RPC endpoint for the web app. If unset, a public endpoint is
# used. Copy this file to `.env.local` and set your own endpoint for higher limits.
VITE_OPENPERPS_RPC=

# Optional overrides for the on-chain program id and the indexer base URL.
# VITE_OPENPERPS_PROGRAM_ID=
# VITE_OPENPERPS_INDEXER=
